# PostgreSQL (required)
DATABASE_URL=postgresql+asyncpg://recruitiq:recruitiq_secret@localhost:5432/recruitiq

# OpenAI (optional — leave empty to use demo mode)
OPENAI_API_KEY=

# Demo mode: uses intelligent mock AI when no API key is set
DEMO_MODE=true

# Backend
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads
CHROMA_PERSIST_DIR=./chroma_data
MAX_UPLOAD_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=60

# Frontend (create .env.local in project root for Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
